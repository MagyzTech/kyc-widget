{
  "name": "kyc-widget-falconlite",
  "version": "1.2.1",
  "description": "Universal KYC verification widget for Next.js and React Native",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "files": [
    "dist",
    "REACT_NATIVE.md"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./styles.css": "./dist/index.css"
  },
  "scripts": {
    "dev": "tsup --watch",
    "build": "tsup",
    "type-check": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "kyc",
    "verification",
    "widget",
    "react",
    "nextjs",
    "bvn",
    "identity"
  ],
  "author": "Falconite",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/MagyzTech/kyc-widget"
  },
  "peerDependencies": {
    "framer-motion": "^11.0.0 || ^12.0.0",
    "lucide-react": "^0.400.0 || ^0.474.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "zod": "^3.22.0",
    "face-api.js": "^0.22.2",
    "lottie-web": "^5.13.0"
  },
  "dependencies": {
    "axios": "^1.7.9",
    "react-webcam": "^7.2.0",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "autoprefixer": "^10.4.17",
    "postcss": "^8.4.33",
    "tailwindcss": "^3.4.1",
    "tsup": "^8.0.1",
    "typescript": "^5.3.3"
  }
}
